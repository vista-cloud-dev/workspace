#!/usr/bin/env bash
#
# git-update-repos — pull the latest version of every git repo in the current directory.
#
# Iterates over each immediate subdirectory, and for any that is a git
# working tree, fetches and fast-forwards the current branch.

set -uo pipefail

# Colors (disabled if output is not a terminal).
if [[ -t 1 ]]; then
  BOLD=$'\033[1m'; RED=$'\033[31m'; GREEN=$'\033[32m'; YELLOW=$'\033[33m'; RESET=$'\033[0m'
else
  BOLD=''; RED=''; GREEN=''; YELLOW=''; RESET=''
fi

updated=0 skipped=0 failed=0

for dir in */; do
  dir=${dir%/}

  # Only consider directories that are git working trees.
  if ! git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    continue
  fi

  printf '%s==> %s%s\n' "$BOLD" "$dir" "$RESET"

  # Refuse to touch repos with uncommitted changes.
  if [[ -n "$(git -C "$dir" status --porcelain)" ]]; then
    printf '  %sskipped: uncommitted changes%s\n' "$YELLOW" "$RESET"
    ((skipped++))
    continue
  fi

  branch=$(git -C "$dir" symbolic-ref --short -q HEAD)
  if [[ -z "$branch" ]]; then
    printf '  %sskipped: detached HEAD%s\n' "$YELLOW" "$RESET"
    ((skipped++))
    continue
  fi

  # Make sure the branch tracks an upstream before pulling.
  if ! git -C "$dir" rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' >/dev/null 2>&1; then
    printf '  %sskipped: branch %s has no upstream%s\n' "$YELLOW" "$branch" "$RESET"
    ((skipped++))
    continue
  fi

  if git -C "$dir" pull --ff-only --quiet; then
    printf '  %supdated (%s)%s\n' "$GREEN" "$branch" "$RESET"
    ((updated++))
  else
    printf '  %sfailed to pull%s\n' "$RED" "$RESET"
    ((failed++))
  fi
done

printf '\n%sDone:%s %d updated, %d skipped, %d failed\n' \
  "$BOLD" "$RESET" "$updated" "$skipped" "$failed"

# Exit non-zero if any pull failed, so callers/CI can detect it.
[[ "$failed" -eq 0 ]]
